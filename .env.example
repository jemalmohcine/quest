# -----------------------------------------------------------------------------
# Next.js (client — préfixe NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Données métier : le front appelle /api/v1/* (session via cookies Supabase).

# -----------------------------------------------------------------------------
# Supabase (Auth + Postgres)
# -----------------------------------------------------------------------------
# Tableau de bord : Settings > API — URL du projet et clé anon (publique).
# Redirect OAuth : ajouter http://localhost:3000/auth/callback (et la prod).
# Schéma SQL : supabase/schema.sql
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# -----------------------------------------------------------------------------
# Gemini (IA) — serveur uniquement (routes /api/v1/gemini/*), jamais NEXT_PUBLIC_
# Accepté : GEMINI_API_KEY ou GEMINI_API_KEY_NEW (ou GOOGLE_API_KEY).
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""
# GEMINI_API_KEY_NEW=""

# -----------------------------------------------------------------------------
# Legacy (Vite) — à supprimer une fois migré : utiliser NEXT_PUBLIC_* ci-dessus
# -----------------------------------------------------------------------------
# APP_URL=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
