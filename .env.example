# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# URL publique de l’applet (liens, OAuth, API). En AI Studio : injecté automatiquement.
APP_URL="MY_APP_URL"

# -----------------------------------------------------------------------------
# Gemini (IA)
# -----------------------------------------------------------------------------
# Clé API Gemini. AI Studio peut l’injecter via les secrets utilisateur.
# Alias historique pris en charge par vite.config (GEMINI_API_KEY).
GEMINI_API_KEY_NEW=""

# -----------------------------------------------------------------------------
# Firebase : toutes les valeurs viennent de la console Firebase :
# Paramètres du projet > Général > Vos applications > Configuration SDK (Web).
# Préfixe VITE_ requis pour que Vite expose ces variables au code client.
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# Analytics (Firebase / Google Analytics) : laisser vide si non utilisé
VITE_FIREBASE_MEASUREMENT_ID=""
# Base Firestore nommée : laisser vide pour la base par défaut "(default)"
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
