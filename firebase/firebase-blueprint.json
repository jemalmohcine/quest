{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "language": { "type": "string", "enum": ["en", "fr"] },
        "dailyObjective": { "type": "integer" },
        "objectivePerPillar": {
          "type": "object",
          "properties": {
            "soulset": { "type": "integer" },
            "healthset": { "type": "integer" },
            "mindset": { "type": "integer" },
            "skillset": { "type": "integer" },
            "heartset": { "type": "integer" }
          }
        }
      },
      "required": ["email", "name", "createdAt", "language", "dailyObjective", "objectivePerPillar"]
    },
    "Deed": {
      "title": "Deed",
      "description": "A single good deed or action performed by the user",
      "type": "object",
      "properties": {
        "pillar": { "type": "string", "enum": ["soulset", "healthset", "mindset", "skillset", "heartset"] },
        "actionName": { "type": "string" },
        "duration": { "type": "integer" },
        "thought": { "type": "string" },
        "feeling": { "type": "string", "enum": ["happy", "confident", "frustrated", "neutral", "energized", "calm", "motivated", "peaceful", "tired", "focused"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "date": { "type": "string" },
        "week": { "type": "integer" },
        "month": { "type": "string" },
        "year": { "type": "integer" },
        "time": { "type": "string" }
      },
      "required": ["pillar", "actionName", "feeling", "createdAt", "date", "week", "month", "year", "time"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User's profile document"
    },
    "/users/{userId}/deeds/{deedId}": {
      "schema": "Deed",
      "description": "Collection of deeds for a specific user"
    }
  }
}
